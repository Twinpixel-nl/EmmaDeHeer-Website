<style>
    /* Zorg dat de p5 container de hele hero vult en erachter staat */
    #p5-hero-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1; /* Achter de tekst */
        overflow: hidden;
    }
    .hero {
        position: relative; /* Nodig voor de absolute positionering van de achtergrond */
        overflow: hidden;
    }
</style>