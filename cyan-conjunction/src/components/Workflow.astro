---
---
<section id="journey" class="timeline-section content-section">
    <div class="section-header fade-in">
        <h2 class="section-title">Mijn Reis</h2>
        <p class="section-subtitle">Een overzicht van mijn professionele groei en de impact die ik heb gemaakt.</p>
    </div>

    <div class="timeline-wrapper">
        <!-- De Verticale Lijn -->
        <div class="timeline-line-container">
            <svg class="timeline-svg" preserveAspectRatio="none" viewBox="0 0 10 1000">
                <path d="M 5 0 L 5 1000" class="line-bg"></path>
                <path d="M 5 0 L 5 1000" class="line-progress"></path>
            </svg>
        </div>

        <div class="timeline-items">
            <!-- ITEM 1: WUR -->
            <div class="timeline-item fade-in">
                <div class="timeline-dot-outer"><div class="timeline-dot-inner"></div></div>
                <div class="timeline-card">
                    <div class="card-header">
                        <span class="timeline-date">2024 — Heden</span>
                        <h3>User Experience Designer</h3>
                        <p class="company-name">Wageningen University & Research</p>
                    </div>
                    <p class="timeline-text">
                        Verantwoordelijk voor het verbeteren van de digitale platformen, waarbij ik de brug sla tussen academische behoeften en technische innovatie.
                    </p>
                    <div class="skill-tags">
                        <span>User Research</span>
                        <span>Wireframing</span>
                        <span>Stakeholder Management</span>
                    </div>
                </div>
            </div>

            <!-- ITEM 2: Jongerenraad -->
            <div class="timeline-item fade-in">
                <div class="timeline-dot-outer"><div class="timeline-dot-inner"></div></div>
                <div class="timeline-card">
                    <div class="card-header">
                        <span class="timeline-date">2025 — Heden</span>
                        <h3>Grafisch Designer</h3>
                        <p class="company-name">Jongerenraad</p>
                    </div>
                    <p class="timeline-text">
                        Vrijwillige inzet voor het creëren van visuele communicatie, van social media identiteit tot fysiek promomateriaal.
                    </p>
                    <div class="skill-tags">
                        <span>Branding</span>
                        <span>Visual Identity</span>
                        <span>Creative Strategy</span>
                    </div>
                </div>
            </div>

            <!-- ITEM 3: Compassion -->
            <div class="timeline-item fade-in">
                <div class="timeline-dot-outer"><div class="timeline-dot-inner"></div></div>
                <div class="timeline-card">
                    <div class="card-header">
                        <span class="timeline-date">2023 — 2024</span>
                        <h3>UX Designer Stage</h3>
                        <p class="company-name">Compassion Nederland</p>
                    </div>
                    <p class="timeline-text">
                        Focus op het ontwikkelen van een reis-app concept binnen een Agile/Scrum team, inclusief data-analyse en prototyping.
                    </p>
                    <div class="skill-tags">
                        <span>Agile/Scrum</span>
                        <span>A/B Testing</span>
                        <span>TypeScript</span>
                        <span>Figma</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>