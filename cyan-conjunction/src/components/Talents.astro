---
---
<section id="talents" class="talents-section content-section">
    <div class="section-header fade-in">
        <h2 class="section-title">Toolbox & Expertise</h2>
        <p class="section-subtitle">De tools en methodieken die ik dagelijks gebruik om complexe vraagstukken op te lossen.</p>
    </div>

    <div class="toolbox-grid">
        <!-- FIGMA -->
        <div class="tool-card fade-in">
            <div class="tool-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 5.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0ZM12 5.5V12M12 12a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0ZM12 12h5.5a2.5 2.5 0 1 1 0 5H12M12 12v6.5a2.5 2.5 0 1 1-5 0V12" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3>Figma</h3>
            <div class="skill-level">
                <div class="level-bar"><div class="level-fill" style="width: 100%;"></div></div>
                <span>Expert</span>
            </div>
            <p>Mastering components, auto-layout en high-fidelity prototyping voor naadloze overdrachten.</p>
        </div>

        <!-- CANVA -->
        <div class="tool-card fade-in">
            <div class="tool-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3>Canva</h3>
            <div class="skill-level">
                <div class="level-bar"><div class="level-fill" style="width: 90%;"></div></div>
                <span>Advanced</span>
            </div>
            <p>Snelle creatie van social media content, presentaties en branding assets.</p>
        </div>

        <!-- CODE -->
        <div class="tool-card fade-in">
            <div class="tool-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3>HTML & CSS</h3>
            <div class="skill-level">
                <div class="level-bar"><div class="level-fill" style="width: 75%;"></div></div>
                <span>Proficient</span>
            </div>
            <p>Mijn designs tot leven brengen met schone, semantische code en responsive layouts.</p>
        </div>

        <!-- CERTIFICATE 1 -->
        <div class="cert-card fade-in">
            <div class="cert-badge">C1</div>
            <div class="cert-content">
                <h3>English Proficiency</h3>
                <span class="cert-status">Gecertificeerd (C1)</span>
                <p>Professionele vaardigheid in woord en geschrift voor internationale samenwerkingen.</p>
            </div>
        </div>

        <!-- CERTIFICATE 2 -->
        <div class="cert-card fade-in">
            <div class="cert-badge green-belt">LSS</div>
            <div class="cert-content">
                <h3>Lean Six Sigma</h3>
                <span class="cert-status">Green Belt</span>
                <p>Expertise in procesverbetering en efficiënte workflow management.</p>
            </div>
        </div>
    </div>
</section>