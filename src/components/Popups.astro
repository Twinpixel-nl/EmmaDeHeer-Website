---
---
<!-- UI/UX DESIGN POPUP -->
<div id="popup-ux" class="popup-modal" aria-hidden="true">
    <div class="popup-content">
        <button class="popup-close" aria-label="Sluit popup">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        
        <div class="popup-header">
            <span class="category-tag">Portfolio</span>
            <h2>UI/UX Design</h2>
            <p>Het vertalen van complexe wensen naar intuïtieve interfaces en naadloze interacties.</p>
        </div>

        <div class="popup-grid">
            <a href="https://bybrittnails.nl/" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/website.png" alt="ByBritt Nails">
                </div>
                <div class="card-details">
                    <h3>ByBritt Nails</h3>
                    <p>Figma • User Research • Web Development</p>
                </div>
            </a>

            <a href="https://socialmediamanager.nl/" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/website1.png" alt="Social Media Manager">
                </div>
                <div class="card-details">
                    <h3>SocialMediaManager.nl</h3>
                    <p>UI Design • Prototyping</p>
                </div>
            </a>

            <a href="https://svnull.nl/" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/website2.png" alt="SV Null">
                </div>
                <div class="card-details">
                    <h3>SV Null Website</h3>
                    <p>UI Design • CMS Architecture</p>
                </div>
            </a>

            <a href="https://vvdwageningen.nl/" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/website3.png" alt="VVD Wageningen">
                </div>
                <div class="card-details">
                    <h3>VVD Wageningen</h3>
                    <p>UX Audit • CMS Management</p>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- BRANDING POPUP -->
<div id="popup-branding" class="popup-modal" aria-hidden="true">
    <div class="popup-content">
        <button class="popup-close" aria-label="Sluit popup">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        
        <div class="popup-header">
            <span class="category-tag">Identity</span>
            <h2>Branding & Design</h2>
            <p>Visuele identiteiten die een verhaal vertellen en een blijvende indruk achterlaten.</p>
        </div>

        <div class="popup-grid">
            <a href="https://www.canva.com/design/DAGrZgh-oSg/CZon1jn6CXoB89rXkxuuNQ/edit" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/branding.png" alt="Huisstijl Project">
                </div>
                <div class="card-details">
                    <h3>Nieuwe Huisstijl</h3>
                    <p>Logo • Styleguide • Marketing Assets</p>
                </div>
            </a>
            <!-- Herhaal project-card structuur voor branding1, branding2 en branding3 -->
             <a href="https://www.canva.com/design/DAGi3iwCtKw/2nNbyrUX_OijzdNATO5ZHg/edit" target="_blank" class="project-card">
                <div class="image-wrapper">
                    <img src="/images/branding1.png" alt="Brandbook Design">
                </div>
                <div class="card-details">
                    <h3>Brandbook Design</h3>
                    <p>Logo • Brand Identity</p>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- MOBILE APPS POPUP -->
<div id="popup-apps" class="popup-modal" aria-hidden="true">
    <div class="popup-content">
        <button class="popup-close" aria-label="Sluit popup">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        
        <div class="popup-header">
            <span class="category-tag">Mobile</span>
            <h2>App Concepts</h2>
            <p>Mobile-first oplossingen gefocust op snelheid en gebruiksgemak.</p>
        </div>

        <div class="popup-grid">
            <div class="project-card no-link">
                <div class="image-wrapper">
                    <img src="/images/app1.png" alt="Travel App">
                </div>
                <div class="card-details">
                    <h3>Travel App</h3>
                    <p>UI Design • Component Library</p>
                </div>
            </div>
            <div class="project-card no-link">
                <div class="image-wrapper">
                    <img src="/images/app2.png" alt="Interface Concept">
                </div>
                <div class="card-details">
                    <h3>Interface Concept</h3>
                    <p>Prototyping • User Flow</p>
                </div>
            </div>
        </div>
    </div>
</div>